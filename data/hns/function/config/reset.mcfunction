# Remove Teams

team remove green
team remove yellow


# Remove Scoreboard Objectives

scoreboard objectives remove timers
scoreboard objectives remove boolean
scoreboard objectives remove random
scoreboard objectives remove variable


# Remove Bossbars

bossbar remove yellow
bossbar remove respawn
bossbar remove game_timer


# Kill All Armor Stands

kill @e[type=armor_stand,tag=reset]


# Remove Tags

tag @a remove respawning